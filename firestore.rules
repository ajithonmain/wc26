rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Live data: read-only for all clients.
    // Writes come only from the VPS via Admin SDK, which bypasses these rules.
    match /live/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // FCM subscription docs: write-only for clients (no cross-user reads).
    // Enforces structure — bots can't store arbitrary payloads.
    match /subs/{token} {
      allow read: if false;

      allow create, update: if
        // Doc must contain only these fields
        request.resource.data.keys().hasOnly(['token', 'ts', 'alerts', 'favorites']) &&
        // token: non-empty string, minimum FCM token length (152+ chars)
        request.resource.data.token is string &&
        request.resource.data.token.size() >= 100 &&
        // ts: Unix timestamp
        request.resource.data.ts is number &&
        // alerts: optional list, capped at 50 entries
        (
          !('alerts' in request.resource.data) ||
          (
            request.resource.data.alerts is list &&
            request.resource.data.alerts.size() <= 50
          )
        ) &&
        // favorites: optional list of team names, capped at 48 (total WC teams)
        (
          !('favorites' in request.resource.data) ||
          (
            request.resource.data.favorites is list &&
            request.resource.data.favorites.size() <= 48
          )
        );

      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
